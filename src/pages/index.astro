---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import { XMLParser } from 'fast-xml-parser';

const feeds = [
  {
    name: 'Northern Planning Committee RSS',
    url: 'https://moderngov.cheshireeast.gov.uk/mgRss.aspx?XXR=0&CID=285',
    source: 'Cheshire East ModernGov',
    focus: 'Wilmslow planning',
  },
];

const parser = new XMLParser({
  ignoreAttributes: false,
  attributeNamePrefix: '',
  removeNSPrefix: true,
  textNodeName: 'text',
});

const items = [];
for (const feed of feeds) {
  try {
    const res = await fetch(feed.url, { headers: { 'user-agent': 'Mozilla/5.0' } });
    if (!res.ok) continue;
    const xml = await res.text();
    const parsed = parser.parse(xml);
    const channelItems = parsed?.rss?.channel?.item ?? [];
    for (const entry of (Array.isArray(channelItems) ? channelItems : [channelItems])) {
      if (!entry) continue;
      const title = String(entry.title?.text ?? entry.title ?? '').replace(/\s+/g, ' ').trim();
      const summary = String(entry.description?.text ?? entry.description ?? entry['content:encoded']?.text ?? entry['content:encoded'] ?? '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
      const url = String(entry.link?.text ?? entry.link ?? '').trim();
      if (!title || !url) continue;
      items.push({
        title,
        summary: summary || `Official update from ${feed.name}.`,
        url,
        tag: feed.focus,
        source: feed.source,
      });
      if (items.length >= 8) break;
    }
  } catch {
    // fallback handled below
  }
}

if (!items.length) {
  items.push({
    title: 'Open the Northern Planning Committee RSS feed',
    summary: 'Live feed parsing did not yield items during build, so the site links directly to the official RSS source.',
    url: feeds[0].url,
    tag: 'Wilmslow planning',
    source: feeds[0].source,
  });
}
---
<BaseLayout title="Cheshire East Council News" description="A professional Astro news dashboard for the latest Cheshire East Council updates.">
  <main class="wrap grid" style="gap:18px;">
    <section class="card" style="padding:20px;">
      <div class="pill">Live council updates · public, free, static</div>
      <div style="display:grid; gap:18px; grid-template-columns: 1fr; margin-top:18px;">
        <div>
          <p class="kicker">Cheshire East Council</p>
          <h1 style="font-size:clamp(2.2rem, 10vw, 4.8rem); line-height:0.96; margin-top:12px; max-width:12ch;">Latest news, cleanly presented.</h1>
          <p class="muted" style="font-size:1rem; line-height:1.7; max-width:70ch; margin-top:14px;">A dev-style public site that tracks the council’s latest media releases and surfaces them in a sharper, easier-to-scan format.</p>
        </div>
        <div class="stat">
          <div class="kicker">Source</div>
          <div style="font-size:1.05rem; font-weight:700; margin-top:10px;">Northern Planning Committee RSS</div>
          <div class="muted" style="margin-top:8px; line-height:1.6;">Official Cheshire East ModernGov RSS feed. Better than scraping HTML, and much more stable for planning updates around Wilmslow.</div>
        </div>
      </div>
      <div style="display:grid; gap:12px; margin-top:18px;">
        <a class="btn" href={feeds[0].url} target="_blank" rel="noreferrer">Open RSS feed</a>
        <span class="pill" style="justify-content:center;">Wilmslow planning · RSS · Official source</span>
      </div>
    </section>

    <section class="grid" style="grid-template-columns: 1fr; align-items:start; gap:16px;">
      <div class="grid" style="gap:14px;">
        <div style="display:grid; gap:8px;">
          <p class="kicker">Latest</p>
          <h2 style="font-size:1.55rem;">Recent council releases</h2>
          <div class="muted">Updated at build time</div>
        </div>
        <div class="news">
          {items.map((item) => <NewsCard item={item} />)}
        </div>
      </div>
      <aside class="grid" style="gap:16px;">
        <div class="card" style="padding:20px;">
          <p class="kicker">What this is</p>
          <ul class="muted" style="line-height:1.8; padding-left:18px; margin:12px 0 0;">
            <li>Public, free GitHub Pages deployment</li>
            <li>Astro static site</li>
            <li>Professional dev-style layout</li>
            <li>Latest council news surfaced cleanly</li>
          </ul>
        </div>
        <div class="card" style="padding:20px;">
          <p class="kicker">Next upgrade</p>
          <p class="muted" style="line-height:1.7; margin-top:10px;">If you want, I can later add category filters, a richer feed parser, or a tiny alert form for weekly updates.</p>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
