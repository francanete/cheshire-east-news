---
const { item } = Astro.props;
---
<article class="card" style="padding:18px;">
  <p class="kicker">Latest update</p>
  <h3 style="font-size:1.08rem; line-height:1.35; margin-top:8px;">{item.title}</h3>
  <p class="muted" style="margin:12px 0 16px; line-height:1.6;">{item.summary}</p>
  <a class="btn" href={item.url} target="_blank" rel="noreferrer">Read on council site</a>
</article>
